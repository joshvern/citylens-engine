# Shared
GOOGLE_CLOUD_PROJECT=<PROJECT_ID>
CITYLENS_REGION=<REGION>
CITYLENS_BUCKET=<BUCKET_NAME>

# API: auth (Neon Auth or any OIDC issuer)
# CITYLENS_AUTH_PROVIDER=neon (default) or 'mock' (local/test only — requires CITYLENS_ALLOW_MOCK_AUTH=true)
CITYLENS_AUTH_PROVIDER=neon
CITYLENS_AUTH_ISSUER=
CITYLENS_AUTH_AUDIENCE=
CITYLENS_AUTH_JWKS_URL=
CITYLENS_AUTH_REQUIRED=true
CITYLENS_ALLOW_MOCK_AUTH=false

# API: admin overrides
CITYLENS_ADMIN_AUTH_SUBS=
CITYLENS_ADMIN_EMAILS=

# API: plan / quota
CITYLENS_FREE_MONTHLY_RUNS=5

# API: optional legacy admin API keys for internal scripts ONLY.
# These do NOT authenticate normal users and must remain disabled in normal deployments.
CITYLENS_ALLOW_ADMIN_API_KEYS=false
CITYLENS_ADMIN_API_KEYS=
CITYLENS_ADMIN_API_KEY_HASHES=

# DEPRECATED: CITYLENS_API_KEYS is no longer used to authenticate dashboard users.
# Left for back-compat only; auth now flows via Authorization: Bearer <token>.
CITYLENS_API_KEYS=

# API: interactive docs gate (sha256 of the docs key — never commit the raw secret)
CITYLENS_DOCS_ACCESS_KEY_SHA256=

# API: CORS / collections
CITYLENS_CORS_ORIGINS=https://citylens.dev,https://www.citylens.dev,http://localhost:3000
CITYLENS_RUNS_COLLECTION=runs
CITYLENS_USERS_COLLECTION=users
CITYLENS_AUTH_IDENTITIES_COLLECTION=auth_identities
CITYLENS_USAGE_MONTHS_COLLECTION=usage_months
CITYLENS_SIGN_URLS=0
CITYLENS_SIGN_URL_TTL_SECONDS=300
CITYLENS_DEMO_RUNS_PATH=

# Cloud Run Job trigger (API)
CITYLENS_JOB_NAME=<JOB_NAME>

# Worker
CITYLENS_RUN_ID=
CITYLENS_DOWNLOAD_REFERENCE_DATA=0
CITYLENS_REFERENCE_DATA_DIR=/tmp/reference-data
CITYLENS_REFERENCE_KEEP_ZIPS=0
CITYLENS_BASELINE_FOOTPRINTS_SOURCE=
CITYLENS_LIDAR_SOURCE=
CITYLENS_ORTHO_WMS_URL=https://orthos.its.ny.gov/arcgis/rest/services/wms/2024/MapServer/WMSServer
CITYLENS_IMAGERY_CACHE_PREFIX=inputs
CITYLENS_ORTHO_BBOX_HALF_SIZE_M=120
CITYLENS_ORTHO_WIDTH=1024
CITYLENS_ORTHO_HEIGHT=1024

# Optional: write local pipeline outputs here (defaults to /tmp/runs)
CITYLENS_WORK_ROOT=/tmp/runs
