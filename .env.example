# Shared
GOOGLE_CLOUD_PROJECT=<PROJECT_ID>
CITYLENS_REGION=<REGION>
CITYLENS_BUCKET=<BUCKET_NAME>

# API
CITYLENS_API_KEYS=dev-key-1,dev-key-2
CITYLENS_CORS_ORIGINS=https://citylens.dev,https://www.citylens.dev,http://localhost:3000
CITYLENS_RUNS_COLLECTION=runs
CITYLENS_USERS_COLLECTION=users
CITYLENS_SIGN_URLS=0
CITYLENS_SIGN_URL_TTL_SECONDS=300
CITYLENS_DEMO_RUNS_PATH=

# Cloud Run Job trigger (API)
CITYLENS_JOB_NAME=<JOB_NAME>

# Worker
CITYLENS_RUN_ID=
CITYLENS_DOWNLOAD_REFERENCE_DATA=0
CITYLENS_REFERENCE_DATA_DIR=/tmp/reference-data
CITYLENS_REFERENCE_KEEP_ZIPS=0
CITYLENS_BASELINE_FOOTPRINTS_SOURCE=
CITYLENS_LIDAR_SOURCE=
CITYLENS_ORTHO_WMS_URL=https://orthos.its.ny.gov/arcgis/rest/services/wms/2024/MapServer/WMSServer
CITYLENS_IMAGERY_CACHE_PREFIX=inputs
CITYLENS_ORTHO_BBOX_HALF_SIZE_M=120
CITYLENS_ORTHO_WIDTH=1024
CITYLENS_ORTHO_HEIGHT=1024

# Optional: write local pipeline outputs here (defaults to /tmp/runs)
CITYLENS_WORK_ROOT=/tmp/runs
